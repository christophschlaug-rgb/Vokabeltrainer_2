<?xml version="1.0" encoding="utf-8"?>
<!--
  Erlaubt ausschließlich HTTPS-Verkehr. Kein Cleartext, auch nicht in Debug.
  Damit schützen wir gegen Man-in-the-Middle-Angriffe und versehentliche HTTP-Aufrufe.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
